export defmacro if stx -> syntax-case stx [else] do
  (if c t else e ...) -> %`(case %,c [:true %,t] [_ (%,@e)])
  (if c t) -> %`(case %,c [:true %,t] [_ :nil])
end

export defmacro and stx -> syntax-case stx [] do
  (and) -> %':true
  (and a) -> %`%,a
  (and a b ...) -> %`(case %,a [:true (and %,@b)] [_ :false])
end

export defmacro or stx -> syntax-case stx [] do
  (or) -> %':false
  (or a) -> %`%,a
  (or a b ...) -> %`(case %,a [:true :true] [_ (or %,@b)])
end
